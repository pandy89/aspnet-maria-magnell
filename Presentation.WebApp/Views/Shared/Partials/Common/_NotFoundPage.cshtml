<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CoreFitness | Gym & Fitness Center</title>
    <link rel="stylesheet" href="css/theme.css" />
    <link rel="stylesheet" href="css/site.css" />
</head>
<body>

    <div class="app-layout">
        <!-- Header section -->
        <header>
            <section class="section__header">
                <div class="logotype">
                    <a href="/"><img src="/images/logotype.png" alt="CoreFitness logotype" /></a>
                </div>
                <nav class="main-menu">
                    <ul class="menu">
                        <li class="menu-item"><a class="menu-item-link" href="#">Fitness Centers</a></li>
                        <li class="menu-item"><a class="menu-item-link" href="#">Memberships</a></li>
                        <li class="menu-item menu-item--has-dropdown">
                            <a class="menu-item-link dropdown-toggle" href="#">Training</a>
                            <ul class="dropdown">
                                <li class="menu-item"><a href="#" class="menu-item-dropdown-link">Personal Training</a></li>
                                <li class="menu-item"><a href="#" class="menu-item-dropdown-link">Group Training</a></li>
                                <li class="menu-item"><a href="#" class="menu-item-dropdown-link">Padel</a></li>
                            </ul>
                        </li>
                        <li class="menu-item"><a class="menu-item-link" href="#">Customer Service</a></li>
                        <li class="menu-item"><a class="menu-item-link" href="#">Store</a></li>
                    </ul>
                </nav>
                <nav class="account-menu">
                    <ul class="menu">
                        <li class="menu-item"><a class="menu-item-link" href="#">Become Member</a></li>
                        <li class="menu-item"><button class="btn btn--primary btn--icon" href="#">Sign In</button></li>
                    </ul>
                </nav>
                <!-- I got help from ChatGPT to create the mobile navigation -->
                <button id="mobile-menu-button" data-target="#mobile-menu-flyout" class="btn btn--primary mobile-btn"></button>
                <div id="mobile-menu-flyout" class="mobile-menu-flyout">
                    <nav class="mobile-nav">
                        <div class="mobile-section"></div>
                        <div class="mobile-section"></div>
                    </nav>
                </div>
            </section>
        </header>
        <main>
            <section class="section__not-found">
                <div class="container">
                    <div class="not-found-area">
                        <img class="not-found-image" src="/images/404-error-image.png" />
                        <div class="not-found-content">
                            <h5 class="not-found-headline">Ooops! page not found</h5>
                            <p class="not-found-text">The page you are looking for does not exists.</p>
                            <button class="btn btn--primary btn--icon">Back to Homepage</button>
                        </div>
                    </div>
                </div>
            </section>
        </main>
        <footer>
        </footer>
    </div>

    
    <script src="js/script.js"></script>
</body>
</html>