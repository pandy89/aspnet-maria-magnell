@using Presentation.WebApp.Models
@using Presentation.WebApp.ViewModels
@using System.Security.Claims
@{

    var userEmail = User.Claims.Where(c => c.Type == ClaimTypes.Email).Select(c => c.Value).ToList();
}
@model UpdateMemberVM

<section class="section__my-account">
    <div class="container">
        <h2 class="my-account-headline">My Account</h2>
        <div class="my-account-area">
            <div class="my-account-section-left">
                <div class="my-account-image"><img src="/images/profile-image-avatar.png" /></div>
                    
                <div class="my-account-menu">
                    <h3>Menu Options</h3>
                    <ul class="my-account-menu-list">
                        <li class="my-account-menu-list-item"><a asp-controller="Account" asp-action="My" class="my-account-menu-list-item-link">About Me</a></li>
                        <li class="my-account-menu-list-item"><a asp-controller="Account" asp-action="My" class="my-account-menu-list-item-link">My Membership</a></li>
                        <li class="my-account-menu-list-item"><a asp-controller="Account" asp-action="My" class="my-account-menu-list-item-link">My Bookings</a></li>
                        <form class="my-account-menu-list-item-last" asp-controller="Authentication" asp-action="SignOut" method="post" novalidate>
                            <button class="btn btn--sign-out btn--icon" type="submit">Sign Out</button>
                        </form>
                    </ul>
                </div>
                <div class="remove-account-area">
                    <p class="remove-account-text">If you like to cancel your account click below</p>
                    <form asp-controller="Account" asp-action="DeleteMember" method="post" onsubmit="return confirm('Are you sure you want to permanently delete your account? This action cannot be undone.');">
                        @Html.AntiForgeryToken()
                        <button class="remove-account btn btn--danger" type="submit">Remove Account</button>
                    </form>
                </div>
            </div>            
            
            <!-- TODO: Move "About Me" to partial -->  
            <div class="my-account-section-right">
                <div class="my-account-section-top">
                    <h2 class="my-account-about-me">About Me</h2>
                    <hr class="my-account-hr1" />
                    <form method="post" asp-controller="Account" asp-action="UpdateMember" class="my-account-form-container" novalidate>
                        <div class="my-account-form-group">
                            <label class="my-account-form-label" asp-for="FirstName">First Name</label>
                            <input class="my-account-form-input" asp-for="FirstName" placeholder="Enter First Name" required>
                            <span asp-validation-for="FirstName"></span>
                        </div>
                        <div class="my-account-form-group">
                            <label class="my-account-form-label" asp-for="LastName">Last Name</label>
                            <input class="my-account-form-input" asp-for="LastName" placeholder="Enter Last Name" required>
                        </div>
                        <div class="my-account-form-group">                            
                            <label class="my-account-form-label">Email Address</label>
                            <p class="text-email-form">@User.Identity?.Name</p>                            
                        </div>
                        <div class="my-account-form-group">
                            <label class="my-account-form-label" asp-for="PhoneNumber">Phone Number</label>
                            <input class="my-account-form-input" asp-for="PhoneNumber" placeholder="Enter Phone Number" required>
                        </div>
                        <hr class="my-account-hr2" />
                        <!-- I used ChatGPT to make the html and css for the uploaded section of the form. -->
                        <div class="my-account-form-group">
                            <label class="my-account-form-label" for="profileImage">Profile Image</label>
                            <div class="file-input-wrapper">
                                <input type="file" id="profileImage" name="profileImage" class="file-input-hidden" accept="image/*">
                                <input type="text" class="my-account-form-input file-input-display" placeholder="Upload Profile Image" readonly>
                                <button type="button" class="btn form-input-button file-input-button">Browse</button>
                            </div>
                        </div>
                        <div class="account-save-button">
                            <button type="submit" class="btn btn--primary btn--icon">Save</button>
                        </div>
                    </form>
                </div>
                <div class="my-account-section-middle">
                    <h3 class="my-account-statistic-headline">My Statistics</h3>
                    <div class="my-statistics-area">
                        <!-- Copilot helpt me with the statusbar and css to the elements. -->
                        <div class="my-statistic-text">
                            <p>Check-In (last 30 days)</p>
                            <p>25</p>
                        </div>
                        <div class="stat-bar-wrapper">
                            <div class="stat-bar-grey"></div>
                            <div class="stat-bar-green stat-bar-checkin"></div>
                        </div>
                        <div class="my-statistic-text">
                            <p>Weight Goal</p>
                            <p>50%</p>
                        </div>
                        <div class="stat-bar-wrapper">
                            <div class="stat-bar-grey"></div>
                            <div class="stat-bar-green stat-bar-weight"></div>
                        </div>
                        <div class="my-statistic-text">
                            <p>Current BMI</p>
                            <p>27</p>
                        </div>
                        <div class="stat-bar-wrapper">
                            <div class="stat-bar-grey"></div>
                            <div class="stat-bar-green stat-bar-current"></div>
                        </div>
                    </div>
                </div>
            </div>                
        </div>
    </div>
</section>




