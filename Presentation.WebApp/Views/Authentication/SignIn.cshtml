@using Presentation.WebApp.ViewModels
@{
    Layout = "Layouts/_AuthLayout";

    //Title on the page
    ViewData["Title"] = "Sign In";
}
@model SignInVM

<section class="section__sign-in">
    <div class="container">
        <div class="sign-in-area">
            <div class="sign-in-content">

                @if (TempData["Error"] is string error)
                {
                    <div>
                        <p class="textred400">@error</p>
                    </div>
                }

                <h2>Welcome Back!</h2>
                <p>Log in to continue your fitness journey with full access to your customized program, training history, and progress tracking. Stay consistent, monitor your development, and keep moving forward with the structure and support built into your account.</p>
                <hr />
                <div class="sign-in-external-login">
                    @if (Model.ExternalProviders.Any())
                    {
                        <form asp-controller="Authentication" asp-action="ExternalLogin" method="post" class="external-providers-box">
                            <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />

                            @foreach (var provider in Model.ExternalProviders)
                            {
                                <partial name="ExternalProviders/_@(provider)Button" />
                            }
                        </form>
                    }
                </div>
                <div class="divider">
                    <span>OR CONTINUE WITH</span>
                </div>
                <div class="sign-in-form-area">
                    <form asp-controller="Authentication" asp-action="SignIn" method="post" class="sign-in-form-container" novalidate>
                        <div class="sign-in-form-group">
                            <label class="sign-in-form-label" required">Email Address</label>
                            <input class="sign-in-form-input" />
                            <span></span>
                        </div>
                        <div class="sign-in-form-group">
                            <label class="sign-in-form-label" >Password</label>
                            <input class="sign-in-form-input"  />
                            <span></span>
                        </div>
                        <a href="#" class="sign-in-link">Forgot your password?</a>     
                        <div class="sign-in-block">
                            <button class="btn btn--primary btn--icon sign-in-block-button" type="submit">Continue</button>
                            <div class="sign-in-form-group">
                                <label><input type="checkbox" class="form-checkbox">Accept user terms and conditions</label>
                            </div>
                        </div>
                    </form>
                </div>                        
            </div>
        </div>
    </div>
</section>